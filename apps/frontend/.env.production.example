# ============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN — Opción B: subdominios por tienda
# Resultado: https://mi-tienda.tudominio.com  (cada org en su subdominio)
# Copiá estas variables en tu proveedor (Vercel → Project → Settings → Env Vars)
# ============================================================================

# ── Dominio público ─────────────────────────────────────────────────────────
# Tu dominio raíz. El middleware detecta el subdominio cuando el host termina
# en ".{NEXT_PUBLIC_BASE_DOMAIN}" y resuelve la tienda por su campo `subdomain`.
NEXT_PUBLIC_BASE_DOMAIN=tudominio.com

# URL canónica de la app (sin subdominio). Usada como fallback al construir
# rutas públicas y para enlaces absolutos.
NEXT_PUBLIC_APP_URL=https://tudominio.com
NEXT_PUBLIC_BASE_URL=https://tudominio.com

# ── API ──────────────────────────────────────────────────────────────────────
# En el navegador la app usa origin + '/api' (mismo dominio), así que esto solo
# importa para llamadas server-side. Apuntalo a tu propio dominio.
NEXT_PUBLIC_API_URL=https://tudominio.com/api

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica
NEXT_PUBLIC_SUPABASE_PROJECT_ID=TU_PROYECTO

# Service role (SECRETO — solo server-side, nunca expongas esto al cliente).
# El middleware lo usa (si está) para resolver tenants más rápido.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# Buckets de storage (ajustá a los tuyos)
NEXT_PUBLIC_SUPABASE_BUCKET_PRODUCTS=products
NEXT_PUBLIC_SUPABASE_BUCKET_CAROUSEL=carousel
NEXT_PUBLIC_SUPABASE_BUCKET_BUSINESS_ASSETS=business-assets

# ── Seguridad ────────────────────────────────────────────────────────────────
# Debe estar definido en producción (se usa para validar CSRF en mutaciones).
CSRF_SECRET=genera_un_valor_aleatorio_largo

# ── Flags (apagados en producción) ───────────────────────────────────────────
NEXT_PUBLIC_MOCK_AUTH=false
NEXT_PUBLIC_ENABLE_MOCK_ADMIN=false
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
NODE_ENV=production

# ============================================================================
# PASOS DE INFRAESTRUCTURA (fuera de este archivo)
# ----------------------------------------------------------------------------
# 1) DNS: creá un registro WILDCARD que apunte a tu app:
#       *.tudominio.com   →   (CNAME a tu deploy de Vercel, p.ej. cname.vercel-dns.com)
#       tudominio.com     →   (A/ALIAS o CNAME a tu deploy)
#
# 2) Vercel → Project → Settings → Domains:
#       agregá  tudominio.com        (dominio raíz / panel admin)
#       agregá  *.tudominio.com      (wildcard para las tiendas)
#    Vercel emite el certificado SSL wildcard automáticamente.
#
# 3) Cada tienda debe tener su campo `subdomain` cargado:
#       Panel → /admin/business-config → pestaña "Publicación" → identificador.
#    Ej: "para-vos-cosmeticos"  →  https://para-vos-cosmeticos.tudominio.com
#
# 4) (Opcional, plan pago) Dominio propio por tienda: la org carga su
#    `custom_domain` en la misma pestaña y agrega ese dominio en Vercel.
# ============================================================================
