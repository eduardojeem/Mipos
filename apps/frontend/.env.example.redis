# Redis Configuration for Rate Limiting
# Choose ONE of the following options:

# Option 1: Upstash Redis (Recommended for Vercel/Serverless)
# Get these values from upstash.com console
UPSTASH_REDIS_REST_URL=https://your-namespace-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-api-token

# Option 2: Self-hosted Redis
# REDIS_URL=redis://localhost:6379

# Rate Limiting Settings (optional overrides)
# RATE_LIMIT_WINDOW_MS=600000  # 10 minutes
# RATE_LIMIT_MAX_ATTEMPTS=5
